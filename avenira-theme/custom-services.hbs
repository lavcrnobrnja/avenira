{{!< default}}

{{!-- PAGE HERO --}}
<section class="page-hero bg-pattern">
  <div class="container">
    {{#match @site.locale "=" "en"}}
      <p class="section-label">Our Services</p>
      <h1>Take the busywork off your team's plate</h1>
      <p>We fix the manual processes slowing your business down — from follow-ups to invoicing.</p>
    {{else}}
      <p class="section-label">Nos services</p>
      <h1>Enlevez les tâches répétitives des épaules de votre équipe</h1>
      <p>On corrige les processus manuels qui ralentissent votre entreprise — des suivis jusqu'à la facturation.</p>
    {{/match}}
  </div>
</section>

{{!-- SERVICE 1: Automation Audit --}}
<section class="service-detail wash-blue">
  <div class="container">
    <div class="service-detail-grid">
      <div class="service-detail-content">
        {{#match @site.locale "=" "en"}}
          <p class="section-label">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Step 1
          </p>
          <h2>Automation Audit</h2>
          <p class="hero-subtitle">Find out where you're bleeding time and money.</p>
          <ul class="service-features">
            <li><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Complete process map of your operations</li>
            <li><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 3–5 prioritized automation opportunities</li>
            <li><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Time and cost estimates per opportunity</li>
            <li><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Recommended implementation timeline</li>
            <li><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Grant eligibility assessment</li>
          </ul>
          <p style="font-size:14px;color:var(--text-muted);margin-top:12px;">Timeline: Two weeks</p>
          <div class="service-grant-note">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            <span>Qualifies under ESSOR (up to 50% covered)</span>
          </div>
          <a href="{{@site.url}}/contact/" class="btn btn-primary" style="margin-top:24px;">Discuss an Automation Audit <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
        {{else}}
          <p class="section-label">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Étape 1
          </p>
          <h2>Audit d'automatisation</h2>
          <p class="hero-subtitle">Découvrez où vous perdez du temps et de l'argent.</p>
          <ul class="service-features">
            <li><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Carte complète de vos processus</li>
            <li><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 3 à 5 opportunités d'automatisation priorisées</li>
            <li><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Estimations de temps et de coûts par opportunité</li>
            <li><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Calendrier de mise en œuvre recommandé</li>
            <li><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Évaluation d'admissibilité aux subventions</li>
          </ul>
          <p style="font-size:14px;color:var(--text-muted);margin-top:12px;">Délai : Deux semaines</p>
          <div class="service-grant-note">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            <span>Admissible au programme ESSOR (jusqu'à 50% couvert)</span>
          </div>
          <a href="{{@site.url}}/contact/" class="btn btn-primary" style="margin-top:24px;">Discuter d'un audit <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
        {{/match}}
      </div>
      <div class="service-visual service-visual-card service-visual-card-audit" aria-hidden="true">
        <div class="service-visual-backdrop"></div>
        <div class="service-visual-shell">
          <svg class="service-visual-icon" viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="51" cy="51" r="23"></circle>
            <path d="M68 68L88 88"></path>
            <path d="M51 39V63"></path>
            <path d="M39 51H63"></path>
          </svg>
          <div class="service-visual-grid">
            <span></span><span></span><span></span><span></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

