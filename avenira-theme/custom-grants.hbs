{{!< default}}

{{!-- PAGE HERO --}}
<section class="page-hero bg-pattern">
  <div class="container">
    {{#match @site.locale "=" "en"}}
      <p class="section-label">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        Funding
      </p>
      <h1>Quebec grants can fund up to half your project</h1>
      <p>Government programs cover 25–50% of automation costs. We handle the paperwork.</p>
    {{else}}
      <p class="section-label">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        Financement
      </p>
      <h1>Les subventions québécoises peuvent couvrir jusqu'à la moitié de votre projet</h1>
      <p>Des programmes gouvernementaux couvrent 25 à 50% des coûts d'automatisation. On s'occupe de la paperasse.</p>
    {{/match}}
  </div>
</section>

{{!-- INTRO --}}
<section class="section">
  <div class="container">
    <div style="max-width:720px;margin:0 auto;text-align:center;">
      {{#match @site.locale "=" "en"}}
        <p style="font-size:1.0625rem;color:var(--text-secondary);line-height:1.8;">Most Quebec businesses don't know that provincial and federal programs exist specifically to fund automation and digital transformation projects. Two out of three SMBs miss out simply because they've never heard of these programs. We help you find the right programs, prepare strong applications, and maximize your funding.</p>
      {{else}}
        <p style="font-size:1.0625rem;color:var(--text-secondary);line-height:1.8;">La plupart des entreprises québécoises ne savent pas que des programmes provinciaux et fédéraux existent spécifiquement pour financer les projets d'automatisation et de transformation numérique. Deux PME sur trois passent à côté simplement parce qu'elles n'ont jamais entendu parler de ces programmes. Nous vous aidons à trouver les bons programmes, préparer des demandes solides et maximiser votre financement.</p>
      {{/match}}
    </div>
  </div>
</section>

{{!-- GRANTS LIST --}}
<section class="section wash-green" style="padding-top:0;">
  <div class="container">
    <div class="text-center" style="margin-bottom:12px;">
      {{#match @site.locale "=" "en"}}
        <h2 class="section-title">Available Programs</h2>
        <p class="section-subtitle">Five programs that can fund your automation project.</p>
      {{else}}
        <h2 class="section-title">Programmes disponibles</h2>
        <p class="section-subtitle">Cinq programmes qui peuvent financer votre projet d'automatisation.</p>
      {{/match}}
    </div>

    <div class="grants-list">
      {{!-- ESSOR --}}
      <div class="grant-card">
        <div class="grant-initial">E</div>
        <div class="grant-info">
          <h3>ESSOR</h3>
          {{#match @site.locale "=" "en"}}
            <p>Up to 50% covered for SMB digital transformation. Consulting, implementation, and training.</p>
          {{else}}
            <p>Jusqu'à 50% couvert pour la transformation numérique des PME. Consultation, implantation et formation.</p>
          {{/match}}
        </div>
        {{#match @site.locale "=" "en"}}
          <div class="grant-badge">Up to $50K · 50%</div>
        {{else}}
          <div class="grant-badge">Jusqu'à 50K$ · 50%</div>
        {{/match}}
      </div>
      {{!-- OTN --}}
      <div class="grant-card">
        <div class="grant-initial">O</div>
        <div class="grant-info">
          <h3>Offensive de transformation numérique (OTN)</h3>
          {{#match @site.locale "=" "en"}}
            <p>Up to 50% for digital transformation projects focused on productivity and technology adoption.</p>
          {{else}}
            <p>Jusqu'à 50% pour les projets de transformation numérique axés sur la productivité et l'adoption technologique.</p>
          {{/match}}
        </div>
        {{#match @site.locale "=" "en"}}
          <div class="grant-badge">Up to $25K · 50%</div>
        {{else}}
          <div class="grant-badge">Jusqu'à 25K$ · 50%</div>
        {{/match}}
      </div>
      {{!-- CRIC --}}
      <div class="grant-card">
        <div class="grant-initial">C</div>
        <div class="grant-info">
          <h3>CRIC (Scientific Research Tax Credit)</h3>
          {{#match @site.locale "=" "en"}}
            <p>30% refundable tax credit for R&amp;D including process automation and technology integration.</p>
          {{else}}
            <p>Crédit d'impôt remboursable de 30% pour la R&amp;D incluant l'automatisation de processus et l'intégration technologique.</p>
          {{/match}}
        </div>
        {{#match @site.locale "=" "en"}}
          <div class="grant-badge">30% tax credit</div>
        {{else}}
          <div class="grant-badge">Crédit de 30%</div>
        {{/match}}
      </div>
      {{!-- Plan PME --}}
      <div class="grant-card">
        <div class="grant-initial">P</div>
        <div class="grant-info">
          <h3>Plan PME</h3>
          {{#match @site.locale "=" "en"}}
            <p>$494M government investment in Quebec SMBs. Productivity, optimization, and digital adoption.</p>
          {{else}}
            <p>494M$ d'investissement gouvernemental dans les PME québécoises. Productivité, optimisation et adoption numérique.</p>
          {{/match}}
        </div>
        {{#match @site.locale "=" "en"}}
          <div class="grant-badge">$494M program</div>
        {{else}}
          <div class="grant-badge">Programme de 494M$</div>
        {{/match}}
      </div>
      {{!-- PME MTL --}}
      <div class="grant-card">
        <div class="grant-initial">M</div>
        <div class="grant-info">
          <h3>PME MTL</h3>
          {{#match @site.locale "=" "en"}}
            <p>Montreal-specific funding and technical assistance for businesses modernizing operations.</p>
          {{else}}
            <p>Financement et assistance technique spécifiques à Montréal pour les entreprises qui modernisent leurs opérations.</p>
          {{/match}}
        </div>
        {{#match @site.locale "=" "en"}}
          <div class="grant-badge">Montreal-specific</div>
        {{else}}
          <div class="grant-badge">Spécifique à Montréal</div>
        {{/match}}
      </div>
    </div>

    {{!-- Important Note --}}
    <div style="margin-top:32px;padding:20px 24px;background:rgba(37,99,235,0.06);border:1px solid rgba(37,99,235,0.12);border-radius:12px;">
      {{#match @site.locale "=" "en"}}
        <p style="font-size:0.9375rem;color:var(--text-secondary);margin:0;line-height:1.7;"><strong style="color:var(--text-primary);">Note:</strong> Grant programs change regularly. Eligibility depends on your specific situation. We research the current landscape for every client and identify the best opportunities. This page reflects programs available as of 2026 and is updated regularly.</p>
      {{else}}
        <p style="font-size:0.9375rem;color:var(--text-secondary);margin:0;line-height:1.7;"><strong style="color:var(--text-primary);">Note :</strong> Les programmes de subventions changent régulièrement. L'admissibilité dépend de votre situation spécifique. Nous analysons le paysage actuel pour chaque client et identifions les meilleures opportunités. Cette page reflète les programmes disponibles en 2026 et est mise à jour régulièrement.</p>
      {{/match}}
    </div>

    {{!-- How We Help --}}
    <div class="grants-help">
      <div class="text-center">
        {{#match @site.locale "=" "en"}}
          <h2 class="section-title">How We Help You Get Funded</h2>
          <p class="section-subtitle">We handle the grant process from assessment to application.</p>
        {{else}}
          <h2 class="section-title">Comment on vous aide à obtenir du financement</h2>
          <p class="section-subtitle">On gère le processus de subvention de l'évaluation à la demande.</p>
        {{/match}}
      </div>
      <div class="grants-help-grid">
        <div class="grants-help-card">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <div>
            {{#match @site.locale "=" "en"}}
              <h4>Assess Eligibility</h4>
              <p>We review your business and project against each program's requirements.</p>
            {{else}}
              <h4>Évaluer l'admissibilité</h4>
              <p>On analyse votre entreprise et votre projet par rapport aux exigences de chaque programme.</p>
            {{/match}}
          </div>
        </div>
        <div class="grants-help-card">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          <div>
            {{#match @site.locale "=" "en"}}
              <h4>Structure the Project</h4>
              <p>We frame your project to maximize grant coverage and approval odds.</p>
            {{else}}
              <h4>Structurer le projet</h4>
              <p>On structure votre projet pour maximiser la couverture et les chances d'approbation.</p>
            {{/match}}
          </div>
        </div>
        <div class="grants-help-card">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          <div>
            {{#match @site.locale "=" "en"}}
              <h4>Prepare Applications</h4>
              <p>We write the complete application package. You sign and submit.</p>
            {{else}}
              <h4>Préparer les demandes</h4>
              <p>On rédige le dossier complet. Vous signez et soumettez.</p>
            {{/match}}
          </div>
        </div>
        <div class="grants-help-card">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <div>
            {{#match @site.locale "=" "en"}}
              <h4>Coordinate Timelines</h4>
              <p>We align project milestones with grant deadlines and reporting.</p>
            {{else}}
              <h4>Coordonner les échéanciers</h4>
              <p>On aligne les étapes du projet avec les échéances et les rapports requis.</p>
            {{/match}}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{{!-- CTA --}}
<section class="cta-section bg-pattern">
  <div class="container">
    {{#match @site.locale "=" "en"}}
      <h2>Find Out What You Qualify For</h2>
      <p>Free assessment of your grant eligibility. No commitment.</p>
      <div class="hero-actions">
        <a href="{{@site.url}}/contact/" class="btn btn-green">Check Your Eligibility <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
      </div>
    {{else}}
      <h2>Découvrez ce à quoi vous avez droit</h2>
      <p>Évaluation gratuite de votre admissibilité. Sans engagement.</p>
      <div class="hero-actions">
        <a href="{{@site.url}}/contact/" class="btn btn-green">Vérifier votre admissibilité <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
      </div>
    {{/match}}
  </div>
</section>
