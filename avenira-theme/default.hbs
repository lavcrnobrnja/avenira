<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{meta_title}}</title>

  {{!-- Hreflang for bilingual SEO --}}
  {{#match @site.locale "=" "en"}}
    <link rel="alternate" hreflang="en" href="https://avenira.ai/">
    <link rel="alternate" hreflang="fr" href="https://avenira.ai/fr/">
    <link rel="alternate" hreflang="x-default" href="https://avenira.ai/">
  {{else}}
    <link rel="alternate" hreflang="fr" href="https://avenira.ai/fr/">
    <link rel="alternate" hreflang="en" href="https://avenira.ai/">
    <link rel="alternate" hreflang="x-default" href="https://avenira.ai/">
  {{/match}}

  {{!-- Google Fonts --}}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  {{!-- Theme stylesheet --}}
  <link rel="stylesheet" href="{{asset "css/screen.css"}}">

  {{ghost_head}}
</head>
<body>
  <a href="#main" class="skip-link">{{t "Skip to content"}}</a>

  {{> header}}

  <main id="main">
    {{{body}}}
  </main>

  {{> footer}}

  {{> cookie-banner}}

  <script src="{{asset "js/main.js"}}"></script>
  {{ghost_foot}}
</body>
</html>
