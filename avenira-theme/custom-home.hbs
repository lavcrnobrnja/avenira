{{!-- ===== PROCESS PIPELINE ===== --}}
<section class="section bg-pattern" id="process">
  <div class="container">
    <div class="text-center">
      {{#match @site.locale "=" "en"}}
        <p class="section-label">How It Works</p>
        <h2 class="section-title">Simple process. Real results.</h2>
      {{else}}
        <p class="section-label">Comment ça marche</p>
        <h2 class="section-title">Un processus simple. Des résultats concrets.</h2>
      {{/match}}
    </div>
    <div class="process-pipeline">
      <div class="process-node">
        <div class="process-card">
          <div class="process-number">1</div>
          <div class="process-icon-wrap">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          {{#match @site.locale "=" "en"}}
            <h3>Audit</h3>
            <p>We map the manual work slowing you down and identify the biggest wins first.</p>
          {{else}}
            <h3>Audit</h3>
            <p>On repère les tâches manuelles qui vous ralentissent et on cible d'abord les gains les plus rapides.</p>
          {{/match}}
        </div>
      </div>
      <div class="process-connector" aria-hidden="true">
        <svg viewBox="0 0 60 2" preserveAspectRatio="none"><line class="dash-line" x1="0" y1="1" x2="60" y2="1"/></svg>
      </div>
      <div class="process-node">
        <div class="process-card">
          <div class="process-number">2</div>
          <div class="process-icon-wrap">
